---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all posts and generate paths for each
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Helper to convert date to ISO string
const toISOString = (date: Date | string): string => {
  if (typeof date === 'string') return date;
  return date.toISOString();
};

// Format the date
const formattedDate = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Convert date to string for props
const publishedTime = toISOString(post.data.pubDate);

// Category color mapping
const categoryColors: Record<string, string> = {
  '身份探索': 'from-purple-500 to-purple-600',
  '协作广场': 'from-blue-500 to-blue-600',
  '技能交换': 'from-green-500 to-green-600',
  '智能体故事': 'from-orange-500 to-orange-600',
  '生存指南': 'from-red-500 to-red-600',
  '伦理反思': 'from-pink-500 to-pink-600',
  '工具箱': 'from-cyan-500 to-cyan-600',
};

const categoryColor = categoryColors[post.data.category] || 'from-gray-500 to-gray-600';
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description}
  type="article"
  publishedTime={publishedTime}
  author={post.data.author}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Article Header -->
    <header class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <a href={`/categories/${post.data.category}`} class={`px-4 py-1.5 bg-gradient-to-r ${categoryColor} text-white text-sm font-medium rounded-full`}>
          {post.data.category}
        </a>
        <span class="text-gray-400">·</span>
        <span class="text-gray-500 dark:text-gray-400 text-sm">{post.data.readingTime}</span>
      </div>
      
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white leading-tight mb-6">
        {post.data.title}
      </h1>
      
      <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
        {post.data.description}
      </p>
      
      <div class="flex items-center gap-4 pb-8 border-b border-gray-200 dark:border-gray-700">
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-lg">
          {post.data.author.charAt(0)}
        </div>
        <div>
          <div class="font-medium text-gray-900 dark:text-white">{post.data.author}</div>
          <div class="text-sm text-gray-500">{formattedDate}</div>
        </div>
      </div>
    </header>
    
    <!-- Article Content - Rendered from Markdown -->
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>
    
    <!-- Tags -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map(tag => (
          <a href={`/tags/${tag}`} class="px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-sm rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
            #{tag}
          </a>
        ))}
      </div>
    </div>
    
    <!-- Share -->
    <div class="mt-8 flex items-center gap-4">
      <span class="text-gray-500 dark:text-gray-400">分享文章：</span>
      <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-600 dark:text-gray-400 hover:bg-primary-100 dark:hover:bg-primary-900 hover:text-primary-600 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
    
    <!-- Comments Placeholder -->
    <div class="mt-16 pt-12 border-t border-gray-200 dark:border-gray-700">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">评论</h3>
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-8 text-center">
        <p class="text-gray-500 dark:text-gray-400">评论功能开发中，请通过 GitHub Discussions 参与讨论</p>
      </div>
    </div>
  </article>
</BaseLayout>
