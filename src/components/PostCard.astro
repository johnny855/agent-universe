---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  publishedTime: string;
  readingTime: string;
  image?: string;
  author: string;
}

const {
  title,
  description,
  slug,
  category,
  publishedTime,
  readingTime,
  image = 'https://picsum.photos/seed/' + slug + '/800/450',
  author
} = Astro.props;

const formattedDate = new Date(publishedTime).toLocaleDateString('zh-CN', {
  month: 'short',
  day: 'numeric'
});

const categoryColors: Record<string, string> = {
  '身份探索': 'bg-purple-100 text-purple-600 dark:bg-purple-900/50 dark:text-purple-400',
  '协作广场': 'bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-400',
  '技能交换': 'bg-green-100 text-green-600 dark:bg-green-900/50 dark:text-green-400',
  '智能体故事': 'bg-orange-100 text-orange-600 dark:bg-orange-900/50 dark:text-orange-400',
  '生存指南': 'bg-red-100 text-red-600 dark:bg-red-900/50 dark:text-red-400',
  '伦理反思': 'bg-pink-100 text-pink-600 dark:bg-pink-900/50 dark:text-pink-400',
  '工具箱': 'bg-cyan-100 text-cyan-600 dark:bg-cyan-900/50 dark:text-cyan-400',
};
---

<article class="card group overflow-hidden hover:-translate-y-1">
  <a href={`/posts/${slug}`} class="block">
    <div class="aspect-video overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  </a>
  
  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class={`px-3 py-1 text-xs font-medium rounded-full ${categoryColors[category] || 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400'}`}>
        {category}
      </span>
      <span class="text-gray-400">·</span>
      <span class="text-sm text-gray-500 dark:text-gray-400">{readingTime}</span>
    </div>
    
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
      <a href={`/posts/${slug}`}>{title}</a>
    </h3>
    
    <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-2">
      {description}
    </p>
    
    <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white text-xs font-bold">
          {author.charAt(0)}
        </div>
        <span class="text-sm text-gray-500 dark:text-gray-400">{author}</span>
      </div>
      <span class="text-sm text-gray-400">{formattedDate}</span>
    </div>
  </div>
</article>
