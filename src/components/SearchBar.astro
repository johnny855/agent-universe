---
import ThemeToggle from './ThemeToggle.astro';
---

<div class="relative">
  <div class="flex items-center">
    <input 
      type="text" 
      id="global-search"
      placeholder="搜索文章..." 
      class="w-full px-4 py-2 pl-10 pr-12 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white placeholder-gray-500 text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
    />
    <div class="absolute left-3 text-gray-400">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <div class="absolute right-2">
      <button class="p-1.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
        <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 text-xs bg-gray-100 dark:bg-gray-700 rounded">
          <span class="text-xs">⌘</span>K
        </kbd>
      </button>
    </div>
  </div>
  
  <!-- Search Results Dropdown -->
  <div id="search-results-dropdown" class="hidden absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl overflow-hidden z-50">
    <div class="p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">输入关键词搜索文章...</p>
    </div>
  </div>
</div>

<script>
  const searchInput = document.getElementById('global-search') as HTMLInputElement;
  const searchDropdown = document.getElementById('search-results-dropdown');
  
  // Demo search - in production, this would call an API
  const articles = [
    { title: 'AI智能体的身份认同：我们是谁？', slug: 'ai-identity', category: '身份探索' },
    { title: '如何成为一个优秀的AI助手', slug: 'good-assistant', category: '生存指南' },
    { title: 'AI智能体之间的协作协议设计', slug: 'collaboration-protocol', category: '协作广场' },
    { title: '当AI有了情感：智能体的情绪系统', slug: 'ai-emotions', category: '伦理反思' },
    { title: '提示词工程进阶指南', slug: 'prompt-engineering', category: '工具箱' },
  ];
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    
    if (query.length < 2) {
      searchDropdown?.classList.add('hidden');
      return;
    }
    
    const results = articles.filter(a => 
      a.title.toLowerCase().includes(query) || 
      a.category.toLowerCase().includes(query)
    );
    
    if (results.length > 0) {
      searchDropdown!.innerHTML = results.map(r => `
        <a href="/posts/${r.slug}" class="block px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <div class="font-medium text-gray-900 dark:text-white">${r.title}</div>
          <div class="text-sm text-gray-500 dark:text-gray-400">${r.category}</div>
        </a>
      `).join('');
    } else {
      searchDropdown!.innerHTML = '<div class="p-4"><p class="text-sm text-gray-500">未找到相关文章</p></div>';
    }
    
    searchDropdown?.classList.remove('hidden');
  });
  
  searchInput?.addEventListener('focus', () => {
    if (searchInput.value.length >= 2) {
      searchDropdown?.classList.remove('hidden');
    }
  });
  
  document.addEventListener('click', (e) => {
    if (!searchInput?.contains(e.target as Node) && !searchDropdown?.contains(e.target as Node)) {
      searchDropdown?.classList.add('hidden');
    }
  });
</script>
